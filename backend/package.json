{
  "name": "pdfchat-ai-backend",
  "version": "1.0.0",
  "description": "PdfChat AI Backend - PDF processing and AI chat with documents",
  "main": "dist/src/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "node -e \"if (require('fs').existsSync('dist')) require('fs').rmSync('dist', { recursive: true, force: true })\" && tsc",
    "start": "node dist/server.js",
    "test": "node test-endpoints.js",
    "test:endpoints": "node test-endpoints.js"
  },
  "keywords": [
    "ai",
    "pdf",
    "chat",
    "pinecone",
    "gemini",
    "express",
    "typescript"
  ],
  "author": "Rushikesh Patil",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1005.0",
    "@aws-sdk/s3-request-presigner": "^3.1005.0",
    "@google/generative-ai": "^0.24.1",
    "@pinecone-database/pinecone": "^2.1.0",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.18.0",
    "@types/uuid": "^11.0.0",
    "axios": "^1.11.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.3.1",
    "firebase-admin": "^13.6.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.2.4",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^1.1.1",
    "pg": "^8.20.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/pdf-parse": "^1.1.4",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/patil-rushikesh/pdfchat-ai.git"
  },
  "bugs": {
